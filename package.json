{
  "name": "bisteca-gateway",
  "version": "1.0.0",
  "description": "BISTECA - Payment Gateway for Telegram Bots (Pix via Woovi)",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build:dashboard": "cd dashboard && npm install && npx vite build",
    "db:migrate": "npx knex migrate:latest --knexfile knexfile.js",
    "db:rollback": "npx knex migrate:rollback --knexfile knexfile.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "setup": "docker compose up -d && timeout /t 5 && npm run db:migrate"
  },
  "keywords": [
    "pix",
    "payment",
    "gateway",
    "telegram",
    "woovi"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.2",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.1",
    "ioredis": "^5.10.0",
    "knex": "^3.1.0",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "undici": "^7.22.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}